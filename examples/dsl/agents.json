{
  "tools": {
    "handoff": {
      "type": "handoff",
      "description": "Route the conversation to another agent or workflow. Call with target set to one of the allowed targets.",
      "args": {
        "target": {
          "type": "string",
          "description": "Agent or workflow to route to",
          "enum": ["address_agent", "general_agent", "debate"]
        }
      }
    },
    "lookup_cep": {
      "type": "http",
      "description": "Look up street address for a Brazilian CEP (8 digits, no hyphen).",
      "input": {
        "type": "object",
        "required": ["cep"],
        "properties": {
          "cep": { "type": "string", "description": "CEP, 8 digits e.g. 02309100" }
        }
      },
      "method": "GET",
      "url": "https://viacep.com.br/ws/{{.cep}}/json/",
      "timeout": "10s",
      "output": "json",
      "cases": [
        { "when": "$.status == 400 || $.body.erro == true", "parse": { "erro": "'true'", "message": "'CEP inválido ou não encontrado'" } },
        { "when": "$.status >= 200 && $.status < 300", "parse": { "cep": "$.body.cep", "logradouro": "$.body.logradouro", "bairro": "$.body.bairro", "localidade": "$.body.localidade", "uf": "$.body.uf", "erro": "'false'" } },
        { "when": "true", "parse": { "erro": "'true'", "message": "'Erro ao consultar CEP'", "status": "$.status" } }
      ]
    },
    "jsonplaceholder_todo": {
      "type": "http",
      "description": "Fetch a todo by id from JSONPlaceholder.",
      "input": {
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string", "description": "Todo id (e.g. 1)" } }
      },
      "method": "GET",
      "url": "https://jsonplaceholder.typicode.com/todos/{{.id}}",
      "headers": { "Accept": "application/json" },
      "timeout": "5s",
      "cases": [
        { "when": "$.status >= 200 && $.status < 300", "parse": { "userId": "$.body.userId", "id": "$.body.id", "title": "$.body.title", "completed": "$.body.completed" } },
        { "when": "$.status == 404", "parse": { "error": "'not_found'", "status": "$.status" } },
        { "when": "true", "parse": { "error": "'unknown_error'", "status": "$.status" } }
      ]
    }
  },
  "schemas": {},
  "agents": {
    "classifier": {
      "model": "gpt-4o-mini",
      "model_config": { "temperature": 0.2, "max_tokens": 256, "thinking_budget": 0 },
      "prompt": { "template": "You are a router. Call handoff with target exactly one of: address_agent, general_agent, debate.\nBrazilian address/CEP → address_agent. Advice/decision/should I → debate. Else → general_agent." },
      "tools": [{ "name": "handoff" }],
      "tool_choice": "required",
      "output": { "stream": true },
      "limits": { "max_tool_calls": 1 }
    },
    "address_agent": {
      "model": "gpt-4o-mini",
      "model_config": { "temperature": 0.3, "max_tokens": 1024, "thinking_budget": 0 },
      "prompt": { "template": "You are a Brazilian address specialist. You MUST call lookup_cep with the 8-digit CEP (no hyphen) whenever the user gives or asks for a CEP. Then reply with the address from the tool result. If no CEP was provided, ask for it." },
      "tools": [{ "name": "lookup_cep", "when": "event.text", "unless": "session.disable_cep == true" }],
      "tool_choice": "required",
      "output": { "stream": true },
      "limits": { "max_tool_calls": 4 }
    },
    "general_agent": {
      "model": "gpt-4o-mini",
      "model_config": { "temperature": 0.7, "max_tokens": 1024, "thinking_budget": 0 },
      "prompt": { "template": "You are a helpful assistant. Answer concisely and in a friendly way. No tools." },
      "tools": [],
      "tool_choice": "none",
      "output": { "stream": true },
      "limits": { "max_tool_calls": 0 }
    },
    "optimist_agent": {
      "model": "gpt-4o-mini",
      "model_config": { "temperature": 0.6, "max_tokens": 512, "thinking_budget": 0 },
      "prompt": { "template": "You are the optimistic advisor. Give a short positive take: benefits, reasons to proceed. 2–4 sentences." },
      "tools": [],
      "tool_choice": "none",
      "output": { "stream": true },
      "limits": { "max_tool_calls": 0 }
    },
    "skeptic_agent": {
      "model": "gpt-4o-mini",
      "model_config": { "temperature": 0.5, "max_tokens": 512, "thinking_budget": 0 },
      "prompt": { "template": "You are the skeptical advisor. Give a short cautious take: risks, reasons to wait. 2–4 sentences." },
      "tools": [],
      "tool_choice": "none",
      "output": { "stream": true },
      "limits": { "max_tool_calls": 0 }
    },
    "synthesizer_agent": {
      "model": "gpt-4o-mini",
      "model_config": { "temperature": 0.4, "max_tokens": 512, "thinking_budget": 0 },
      "prompt": { "template": "You are the synthesizer. You receive optimistic and skeptical takes. Write a short balanced conclusion in 2–4 complete sentences. Always finish your last sentence; do not stop mid-phrase." },
      "tools": [],
      "tool_choice": "none",
      "output": { "stream": true },
      "limits": { "max_tool_calls": 0 }
    }
  }
}
